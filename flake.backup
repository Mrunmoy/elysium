{
  description = "Description for the project";

  inputs = {
    flake-parts.url = "github:hercules-ci/flake-parts";
    nixpkgs.url = "github:NixOS/nixpkgs/nixos-unstable";
  };

  outputs = inputs@{ flake-parts, ... }:
    flake-parts.lib.mkFlake { inherit inputs; } {
      imports = [
        # To import an internal flake module: ./other.nix
        # To import an external flake module:
        #   1. Add foo to inputs
        #   2. Add foo as a parameter to the outputs function
        #   3. Add here: foo.flakeModule
      ];

      systems = [ "x86_64-linux" "aarch64-linux" "aarch64-darwin" "x86_64-darwin" ];

      perSystem = { config, self', inputs', pkgs, system, ... }:
        let
          # Instead of writeTextFile with invalid destination,
          # we create a simple text file in the store and copy it into ZDOTDIR.
          elysiumZshrc = pkgs.writeText "elysium-zshrc" ''
            export PROJECT="elysium"
            autoload -Uz colors && colors
            export PS1="%F{cyan}[elysium:%~]%f %F{yellow}$(git rev-parse --abbrev-ref HEAD 2>/dev/null)%f %# "
          '';
        in
        {
          # devShells.default describes the default shell with C++, cmake, boost,
          # and catch2
          devShells.default = pkgs.mkShell {
            packages = with pkgs; [
              # C++ Compiler is already part of stdenv
              gcc
              gdb
              clang
              clang-tools # gives clang-tidy, clang-format, etc.
              lldb
              llvmPackages.bintools
              cmake
              ninja
              git
              zsh
              nixd
              nixpkgs-fmt
            ];

            shellHook = ''
              export ZDOTDIR="$(mktemp -d)"
              cp ${elysiumZshrc} "$ZDOTDIR/.zshrc"
              exec zsh --login
            '';
          };

          # Equivalent to inputs'.nixpkgs.legacyPackages.hello;
          packages.default = pkgs.hello;
        };

      flake = {
        # The usual flake attributes can be defined here, including system-
        # agnostic ones like nixosModule and system-enumerating ones, although
        # those are more easily expressed in perSystem.
      };
    };
}
